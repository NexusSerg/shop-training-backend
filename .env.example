# Copy to .env and fill in values

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=shop
POSTGRES_PASSWORD=shop_secret
POSTGRES_DB=shop_catalog

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Elasticsearch
ELASTICSEARCH_URL=http://localhost:9200

# Kafka
KAFKA_BROKERS=localhost:9092

# Service ports
SEARCH_SERVICE_PORT=3001
CATALOG_SERVICE_PORT=3002
PRICING_SERVICE_PORT=3003
AUTOCOMPLETE_SERVICE_PORT=3004
SAVED_SEARCH_SERVICE_PORT=3005

# API Gateway
GATEWAY_PORT=3000
