{
  "name": "@shop/catalog-service",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/main.ts",
    "start": "node dist/main.js",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist",
    "db:migrate": "NODE_OPTIONS='--env-file=../../.env' prisma migrate deploy",
    "db:seed": "NODE_OPTIONS='--env-file=../../.env' ts-node src/db/seed.ts",
    "db:seed:dev": "NODE_OPTIONS='--env-file=../../.env' ts-node src/db/seed.ts --count 10000",
    "prisma:generate": "prisma generate"
  },
  "dependencies": {
    "@faker-js/faker": "^9.0.0",
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/swagger": "^7.4.0",
    "@prisma/client": "^5.22.0",
    "@shop/shared-types": "workspace:*",
    "@shop/shared-utils": "workspace:*",
    "dotenv": "^17.4.2",
    "pg": "^8.21.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@nestjs/testing": "^10.0.0",
    "@shop/eslint-config": "workspace:*",
    "@swc/core": "^1.15.33",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^6.0.0",
    "prisma": "^5.22.0",
    "supertest": "^7.0.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.5.0",
    "unplugin-swc": "^1.5.9",
    "vitest": "^2.0.0"
  }
}
