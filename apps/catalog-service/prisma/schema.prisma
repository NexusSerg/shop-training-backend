// Prisma schema for the Catalog Service
// Step 3.1 — PostgreSQL persistence layer

generator client {
  provider = "prisma-client-js"
  output   = "../../../node_modules/.pnpm/@prisma+client@5.22.0_prisma@5.22.0/node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum ProductStatus {
  active
  inactive
  draft
  deleted
}

enum SellerStatus {
  active
  inactive
  suspended
}

enum OfferStatus {
  active
  inactive
}

// ---------------------------------------------------------------------------
// Products
// ---------------------------------------------------------------------------

model Product {
  id                String        @id @default(uuid()) @db.Uuid
  sku               String        @unique @db.VarChar(50)
  name              String        @db.VarChar(500)
  description       String        @default("") @db.Text
  brand             String        @db.VarChar(200)
  slug              String        @unique @db.VarChar(600)
  status            ProductStatus @default(draft)
  // primaryCategoryId is the single canonical category — mirrors Product.categoryId in shared-types.
  // product_categories is kept for future multi-category support.
  primaryCategoryId String?       @db.VarChar(100)
  metaTitle         String        @default("") @db.VarChar(200)
  metaDescription   String        @default("") @db.VarChar(500)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  primaryCategory Category?         @relation("ProductPrimaryCategory", fields: [primaryCategoryId], references: [id])
  categories      ProductCategory[]
  attributes      ProductAttribute[]
  images          ProductImage[]
  sellerOffers    SellerOffer[]

  @@index([brand])
  @@index([status])
  @@index([createdAt])
  @@index([primaryCategoryId])
  @@map("products")
}

// ---------------------------------------------------------------------------
// Categories  (adjacency list — parent_id self-reference)
// ---------------------------------------------------------------------------

model Category {
  id        String   @id @db.VarChar(100)
  name      String   @db.VarChar(200)
  slug      String   @db.VarChar(200)
  // path stores the display names from root to this node, e.g. ["Electronics","Laptops"]
  path      String[] @db.Text
  parentId  String?  @db.VarChar(100)

  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children Category[] @relation("CategoryTree")

  primaryProducts   Product[]         @relation("ProductPrimaryCategory")
  productCategories ProductCategory[]

  @@index([parentId])
  @@map("categories")
}

// ---------------------------------------------------------------------------
// Product ↔ Category (many-to-many)
// ---------------------------------------------------------------------------

model ProductCategory {
  productId  String @db.Uuid
  categoryId String @db.VarChar(100)

  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id])

  @@id([productId, categoryId])
  @@index([categoryId])
  @@map("product_categories")
}

// ---------------------------------------------------------------------------
// Product attributes  (EAV — key/value pairs per product)
// ---------------------------------------------------------------------------

model ProductAttribute {
  id         Int     @id @default(autoincrement())
  productId  String  @db.Uuid
  key        String  @db.VarChar(100)
  // value stored as JSON string so it can hold string | string[] | number
  value      String  @db.Text
  label      String  @default("") @db.VarChar(200)
  filterable Boolean @default(false)
  searchable Boolean @default(false)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([key])
  @@index([productId, key])
  @@map("product_attributes")
}

// ---------------------------------------------------------------------------
// Product images
// ---------------------------------------------------------------------------

model ProductImage {
  id        Int     @id @default(autoincrement())
  productId String  @db.Uuid
  url       String  @db.Text
  altText   String  @default("") @db.VarChar(500)
  width     Int     @default(0)
  height    Int     @default(0)
  isPrimary Boolean @default(false)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("product_images")
}

// ---------------------------------------------------------------------------
// Sellers
// ---------------------------------------------------------------------------

model Seller {
  id     String       @id @default(uuid()) @db.Uuid
  name   String       @db.VarChar(200)
  status SellerStatus @default(active)

  offers SellerOffer[]

  @@index([status])
  @@map("sellers")
}

// ---------------------------------------------------------------------------
// Seller offers  (one row per product×seller)
// ---------------------------------------------------------------------------

model SellerOffer {
  id            String      @id @default(uuid()) @db.Uuid
  productId     String      @db.Uuid
  sellerId      String      @db.Uuid
  price         Decimal     @db.Decimal(12, 2)
  originalPrice Decimal     @db.Decimal(12, 2)
  stock         Int         @default(0)
  status        OfferStatus @default(active)
  updatedAt     DateTime    @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  seller  Seller  @relation(fields: [sellerId], references: [id])

  @@unique([productId, sellerId])
  @@index([productId])
  @@index([sellerId])
  @@index([price])
  @@map("seller_offers")
}
